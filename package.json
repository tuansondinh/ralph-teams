{
  "name": "ralph-teams",
  "version": "0.1.3",
  "description": "CLI tool for Ralph Teams",
  "bin": {
    "ralph-teams": "dist/index.js",
    "rjq": "dist/json-tool.js"
  },
  "files": [
    "dist",
    ".claude",
